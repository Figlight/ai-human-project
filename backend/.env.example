# ===========================================
# 景区导览AI数字人 - 环境配置
# 复制此文件为 .env 并填入对应值即可
# 不填任何值也能运行（使用Mock模式）
# ===========================================

# ---------- LLM 大模型 ----------
# 推荐 DeepSeek（便宜）或 阿里Qwen（免费额度多）
# 选一个填即可，不填则使用内置Mock回复
LLM_API_KEY=""
LLM_BASE_URL="https://api.deepseek.com"
LLM_MODEL="deepseek-chat"

# DeepSeek 示例（推荐，注册送500万token）：
# LLM_API_KEY="sk-xxxxxxxxxxxxxxxx"
# LLM_BASE_URL="https://api.deepseek.com"
# LLM_MODEL="deepseek-chat"

# 阿里 Qwen 示例（通义千问）：
# LLM_API_KEY="sk-xxxxxxxxxxxxxxxx"
# LLM_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"
# LLM_MODEL="qwen-turbo"

# OpenAI 兼容接口示例：
# LLM_API_KEY="sk-xxx"
# LLM_BASE_URL="https://api.openai.com/v1"
# LLM_MODEL="gpt-4o-mini"

# ---------- 语音识别 ASR ----------
# 留空使用 Whisper 本地模型（需 pip install openai-whisper）
# 或填写 OpenAI Whisper API
ASR_MODEL="base"
ASR_DEVICE="cpu"
# ASR_API_KEY=""  # 如需使用云端ASR，在此填key

# ---------- 语音合成 TTS ----------
# 留空使用 edge-tts（免费，无需KEY，开箱即用）
# TTS_VOICE 可选: zh-CN-XiaoxiaoNeural(女), zh-CN-YunxiNeural(男)
TTS_VOICE="zh-CN-XiaoxiaoNeural"

# ---------- 知识库 RAG ----------
# 本地向量库，无需API。如需替换嵌入模型可改此值
EMBEDDING_MODEL="BAAI/bge-small-zh-v1.5"
TOP_K=5

# ---------- 数据库 ----------
# 默认 SQLite，可切换 MySQL/PostgreSQL
DATABASE_URL="sqlite+aiosqlite:///./data/app.db"
# MySQL 示例：
# DATABASE_URL="mysql+aiomysql://user:password@localhost:3306/scenic_guide"
# PostgreSQL 示例：
# DATABASE_URL="postgresql+asyncpg://user:password@localhost:5432/scenic_guide"

# ---------- 服务器 ----------
HOST="0.0.0.0"
PORT=8000
DEBUG=true
